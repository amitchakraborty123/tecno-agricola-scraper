# ============================================================
#  .gitignore — Python Scraping / Bot / Automation Projects
# ============================================================

# ----- Python -----
__pycache__/
*.py[cod]
*.pyd
*.pyo
*.pyw
build/
dist/
*.egg-info/
*.egg
MANIFEST
site/

# ----- Virtual Environments -----
venv/
.venv/
env/
.env/
ENV/
venv.bak/
.python-version

# ----- Environment Variables & Secrets -----
.env
.env.*
!.env.example
secrets.py
secrets.json
credentials.json
cookies.json
*.pem
*.key

# ----- Scraped Output -----
# Ignore contents of output/, but keep the folder via .gitkeep
output/*
!output/.gitkeep

# Ignore contents of sample_output/ except the committed CSV
sample_output/*
!sample_output/sample_products.csv

# Ignore loose CSV/data files anywhere else in the project
*.csv
*.json
*.xlsx
*.xml

# ----- Logs -----
# Ignore contents of logs/, but keep the folder via .gitkeep
logs/*
!logs/.gitkeep
*.log
*.log.*

# ----- Database & Cache -----
*.db
*.sqlite
*.sqlite3
*.cache
.cache/
cache/
*.pkl
*.pickle

# ----- Proxy / Session / Browser Artifacts -----
selenium_profiles/
chromedriver
geckodriver
*.crx
playwright-browsers/
.playwright/
user_data/
profiles/

# ----- Jupyter Notebooks -----
.ipynb_checkpoints/

# ----- Testing -----
.pytest_cache/
.tox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ----- Type Checking -----
.mypy_cache/
.dmypy.json
.pyright/
pyrightconfig.json

# ----- IDEs & Editors -----
.vscode/
!.vscode/extensions.json
.idea/
*.iml
*.iws
*.ipr
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
\#*\#
.\#*

# ----- OS Generated -----
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
.Trash-*

# ----- Docker -----
.dockerenv
docker-compose.override.yml

# ----- Misc -----
*.bak
*.tmp
*.temp
*.orig
.todo
TODO.md