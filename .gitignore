# ============================================================
#  .gitignore
# ============================================================


# ----- Python -----
__pycache__/
*.py[cod]
*.pyd
*.pyo
*.pyw
build/
dist/
*.egg-info/
*.egg
MANIFEST
site/


# ----- Virtual Environments -----
venv/
.venv/
env/
.env/
ENV/
venv.bak/
.python-version


# ----- Environment Variables & Secrets -----
.env
.env.*
!.env.example
secrets.py
secrets.json
credentials.json
cookies.json
*.pem
*.key


# ----- Scraped Output (runtime data — never commit) -----
output/
!output/.gitkeep
*.csv
*.json
*.xlsx
*.xml
!sample_output/


# ----- Logs -----
logs/
!logs/.gitkeep
*.log
*.log.*


# ----- Database & Cache -----
*.db
*.sqlite
*.sqlite3
*.cache
.cache/
cache/
*.pkl
*.pickle


# ----- Proxy / Session / Browser Artifacts -----
selenium_profiles/
chromedriver
geckodriver
*.crx
playwright-browsers/
.playwright/
user_data/
profiles/


# ----- Jupyter Notebooks (if used for analysis) -----
.ipynb_checkpoints/
*.ipynb


# ----- Testing -----
.pytest_cache/
.tox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover


# ----- Type Checking -----
.mypy_cache/
.dmypy.json
.pyright/
pyrightconfig.json


# ----- IDEs & Editors -----
# VS Code
.vscode/
!.vscode/extensions.json

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*


# ----- OS Generated -----
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.Trash-*


# ----- Docker (if you ever containerise a bot) -----
.dockerenv
docker-compose.override.yml


# ----- Misc -----
*.bak
*.tmp
*.temp
*.orig
.todo
TODO.md